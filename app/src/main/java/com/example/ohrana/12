// Информационная карточка

Card(
modifier = Modifier.fillMaxWidth(),
colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.secondaryContainer)
) {
    Column(
        modifier = Modifier.padding(16.dp)
    ) {
        Text(
            text = "Информация",
            fontSize = 14.sp,
            fontWeight = FontWeight.Bold,
            color = MaterialTheme.colorScheme.onSecondaryContainer
        )
        Spacer(modifier = Modifier.height(8.dp))
        Text(
            text = "После начала обхода вы попадете в кабинет охранника, где сможете сканировать QR-коды чекпоинтов.",
            fontSize = 12.sp,
            color = MaterialTheme.colorScheme.onSecondaryContainer
        )
    }
}


# 1. Остановить все процессы Java (включая Gradle daemon)
Stop-Process -Name "java" -Force

# 2. Остановить градле демонов напрямую
./gradlew --stop

# 3. Уничтожить все демоны Gradle
./gradlew --stop --info

# 4. Удалить папку build вручную (если файлы заблокированы)
Remove-Item -Recurse -Force "app\build"